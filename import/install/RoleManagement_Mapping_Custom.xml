      <entry key="downloadBatchRequestSummary" value="CNC_RME_Bulk_Request_Batch_Request_Summary"/>
      <entry key="nonEditableFields">
      	<value>
      		<List>
      			<String>secondLevelApprover</String>
      			<String>certifiable</String>
      			<String>approvalLevels</String>      			
      		</List>
      	</value>
      </entry>
      
      <entry key="config">
      	<value>
      		<Map>
      			<entry key="debugEnabled">
			      	<value>
			      		<Boolean>true</Boolean>
			      	</value>
			      </entry>
			      <entry key="helpUrl" value="https://google.com"/>
