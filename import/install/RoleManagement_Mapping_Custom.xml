<?xml version='1.0' encoding='UTF-8'?>
<!DOCTYPE Custom PUBLIC "sailpoint.dtd" "sailpoint.dtd">
<Custom name="Role Management Settings">
  <Attributes>
    <Map>
    <entry key="roleDownloadTimeOutInMilliSeconds">
        <value>
          <Integer>60000</Integer>
        </value>
      </entry>
      <entry key="dashboardRule" value="CNC_RME_DashboardRule"/>
      <entry key="downloadRolesRule" value="CNC_RME_DownloadRolesRule"/>
      <entry key="updateRoleRule" value="CNC_RME_UpdateRole"/>
      <entry key="getWorkgroupMembersRule" value="CNC_RME_GetWorkgroupMembers"/>
      <entry key="bulkUploadTemplateDownloadRule" value="CNC_RME_BulkUpload_Template_Download"/>
