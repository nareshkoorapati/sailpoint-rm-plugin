<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<!DOCTYPE Plugin PUBLIC "sailpoint.dtd" "sailpoint.dtd">
<Plugin displayName="RoleManagement" minSystemVersion="7.1" name="rolemanagement" rightRequired="RoleManagementRight" version="0.1">
  <Attributes>
    <Map>
      <entry key="minUpgradableVersion" value="0.1"/>
      <entry key="fullPage">
        <value>
          <FullPage title="Role Management"/>
        </value>
      </entry>
      <entry key="snippets">
        <value>
          <List>
            <Snippet regexPattern=".*\/home\.?(jsf|xhtml)" rightRequired="RoleManagementRight">
              <Scripts>
                <String>ui/js/RoleManagementBundle.js</String>
              </Scripts>
            </Snippet>
            <!-- <Snippet regexPattern=".*/plugins/pluginPage.jsf" rightRequired="RoleManagementRight">
				<Scripts>
					<String>ui/js/enableRoleManagement.js</String>
				</Scripts>
				<StyleSheets>
				</StyleSheets>
			</Snippet> -->
			<Snippet regexPattern=".*/plugins/pluginPage.jsf">
				<Scripts>
					<String>ui/js/navBarInject.js</String>
				</Scripts>
				<StyleSheets>
				</StyleSheets>
			</Snippet>
          </List>
        </value>
      </entry>
      <entry key="settings">
        <value>
          <List>
            <Setting dataType="string" defaultValue="Role Management Settings" helpText="Custom object which will have config" label="Config Custom Object" name="customObjectName"/>
            <Setting dataType="boolean" defaultValue="true" helpText="Approval Required for Bulk request" label="Bulk Request Approval" name="bulkRequestApproval"/>
          </List>
        </value>
      </entry>
      <entry key="restResources">
        <value>
          <List>
            <String>sailpoint.plugin.rolemanagement.rest.RoleManagementResource</String>
            <String>sailpoint.plugin.rolemanagement.rest.BatchRequestResource</String>
          </List>
        </value>
      </entry>
    </Map>
  </Attributes>
</Plugin>
